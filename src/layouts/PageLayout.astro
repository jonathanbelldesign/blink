---
import '../styles/global.css';
import type { LinksSection, PageContent } from '../types';
import Heading from '../components/sections/Heading.astro';
import Text from '../components/sections/Text.astro';
import Image from '../components/sections/Image.astro';
import Quote from '../components/sections/Quote.astro';
import Links from '../components/sections/Links.astro';
import Embed from '../components/sections/Embed.astro';
import Cta from '../components/sections/Cta.astro';

type Props = { content: PageContent };

const { content } = Astro.props;
const { theme, sections } = content;

const pageTitle = sections.find((s) => s.type === 'heading')?.title ?? 'Page';

const linksSection = sections.find((s): s is LinksSection => s.type === 'links');
const cta = linksSection?.items.at(-1);

const themeStyle = [
	theme?.colors?.background && `--color-bg: ${theme.colors.background}`,
	theme?.colors?.text && `--color-fg: ${theme.colors.text}`,
	theme?.colors?.accent && `--color-accent: ${theme.colors.accent}`,
	theme?.fonts?.heading && `--font-heading: ${theme.fonts.heading}`,
	theme?.fonts?.body && `--font-body: ${theme.fonts.body}`,
]
	.filter(Boolean)
	.join('; ');
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
	</head>
	<body style={themeStyle}>
		<main>
			{sections.map((section) => {
				switch (section.type) {
					case 'heading':
						return <Heading {...section} />;
					case 'text':
						return <Text {...section} />;
					case 'image':
						return <Image {...section} />;
					case 'quote':
						return <Quote {...section} />;
					case 'links':
						return <Links {...section} items={section.items.slice(0, -1)} />;
					case 'embed':
						return <Embed {...section} />;
					default:
						return null;
				}
			})}
			{cta && <Cta item={cta} />}
		</main>
	</body>
</html>
