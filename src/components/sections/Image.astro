---
import type { ImageSection } from '../../types';

type Props = ImageSection;

const { src, caption } = Astro.props;
---

<figure class="image">
  <img src={src} alt={caption ?? ''} loading="lazy" />
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .image {
    margin: 0;
  }

  img {
    width: 100%;
    border: 1px solid var(--color-border);
  }

  figcaption {
    margin-top: 0.5rem;
    font-size: calc(0.85rem * var(--font-scale-body));
    color: var(--color-muted);
    text-align: center;
  }
</style>
